# Build artifacts (Theos)
.theos/
packages/
*.dSYM/
*.o

# Compiled binaries
*.dylib
*.deb
bulletindistributord
companionmessagesd

# Allow packaged .deb in the public APT repo (GitHub Pages)
!docs/debs/*.deb

# Reference/third-party binaries
generalhook_original.dylib
# (layout/ ignore removed in v7.19 — multi-iOS pipeline ships per-build passd binaries
#  in layout/opt/watchpair11/passd_signed_*.bin and they need to be tracked)

# Local environment
*.log

# Device backups (large tarballs, not source)
backups/
/layout/opt/watchpair11/passd_signed

# Allow per-iOS-build pre-signed passd binaries (multi-iOS pipeline, v7.19+)
!/layout/opt/watchpair11/passd_signed_*.bin

# v8.0 — vendored iOS static libs for cross-compiling tools/ct_bypass_ios
# (47 MB total, fetched fresh by tools/fetch_external.sh from ChOma upstream)
/tools/ct_bypass_ios/external/ios/libcrypto.a
/tools/ct_bypass_ios/external/ios/libssl.a
# Staged host openssl headers (regenerated at build time by fetch_external.sh
# or copied manually from /usr/include/openssl/ + the arch-specific one)
/tools/ct_bypass_ios/external/include/
# Vendored ChOma source tree (~400 KB, allowed)
# Theos build artifacts inside tools/
/tools/*/.theos/
/tools/*/packages/
