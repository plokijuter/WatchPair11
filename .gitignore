# Build artifacts (Theos)
.theos/
packages/
*.dSYM/
*.o

# Compiled binaries
*.dylib
*.deb
bulletindistributord
companionmessagesd

# Allow packaged .deb in the public APT repo (GitHub Pages)
!docs/debs/*.deb

# Reference/third-party binaries
generalhook_original.dylib
# (layout/ ignore removed in v7.19 — multi-iOS pipeline ships per-build passd binaries
#  in layout/opt/watchpair11/passd_signed_*.bin and they need to be tracked)

# Local environment
*.log

# Device backups (large tarballs, not source)
backups/
/layout/opt/watchpair11/passd_signed

# Allow per-iOS-build pre-signed passd binaries (multi-iOS pipeline, v7.19+)
!/layout/opt/watchpair11/passd_signed_*.bin
