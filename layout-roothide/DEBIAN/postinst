#!/bin/bash
# WatchPair11 v7.19 — Post-install (roothide variant)
# Single .deb : registers the home-screen app + reloads daemons + rewrites
# the LaunchDaemon plist's __JBROOT__ placeholder for the randomized jbroot.

set -e

# Resolve the randomized jbroot prefix (roothide ships /usr/bin/jbroot).
if command -v jbroot >/dev/null 2>&1; then
  JB="$(jbroot)"
elif [ -d /var/jb ]; then
  # Defensive fallback: a roothide .deb being installed on rootless shouldn't
  # happen (Conflicts in control), but if it does don't brick the device.
  JB="/var/jb"
else
  echo "[WP11] Cannot locate jbroot — abort." >&2
  exit 1
fi

echo "[WP11] jbroot prefix: $JB"

# ---------------------------------------------------------------
# 1. Rewrite __JBROOT__ placeholder inside the LaunchDaemon plist
#    template that ships with the .deb. This must happen before
#    launchd ever sees it.
# ---------------------------------------------------------------
TEMPLATE="${JB}/opt/watchpair11/com.apple.passd.plist"
if [ -f "$TEMPLATE" ]; then
  echo "[WP11] Substituting __JBROOT__ -> $JB inside $TEMPLATE"
  sed -i "s|__JBROOT__|${JB}|g" "$TEMPLATE"
fi

# ---------------------------------------------------------------
# 2. Register the home-screen app (uicache).
# ---------------------------------------------------------------
echo "[WP11] Registering home-screen app..."
if [ -x "${JB}/usr/bin/uicache" ]; then
  "${JB}/usr/bin/uicache" -p "${JB}/Applications/WatchPair11.app" 2>&1 | sed 's/^/[WP11]   /'
elif command -v uicache >/dev/null 2>&1; then
  uicache -p "${JB}/Applications/WatchPair11.app" 2>&1 | sed 's/^/[WP11]   /'
else
  echo "[WP11]   uicache not found — icon may not appear"
fi

# ---------------------------------------------------------------
# 3. Kill Watch-related daemons so they respawn with the tweak loaded.
# ---------------------------------------------------------------
echo "[WP11] Killing Watch-related daemons (they will respawn with the tweak loaded)..."
for d in bluetoothd companionproxyd nptocompaniond terminusd pairedsyncd \
         Bridge identityservicesd imagent apsd appconduitd passd; do
  killall -9 "$d" 2>/dev/null || true
done

cat <<EOF
[WP11] ==========================================
[WP11] WatchPair11 v7.19 (roothide) installed.
[WP11]
[WP11] Open the WatchPair11 app on the home screen
[WP11] for Apple Pay setup, rollback, respring, and
[WP11] userspace reboot.
[WP11]
[WP11] If the tweak does not load into all daemons,
[WP11] you may need to userspace-reboot once via the
[WP11] in-app button.
[WP11]
[WP11] jbroot: ${JB}
[WP11] ==========================================
EOF

exit 0
